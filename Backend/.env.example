PORT=5001
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional provider settings. Leave blank to use deterministic local fallbacks.
FLIGHT_PLAN_DB_API_KEY=
FLIGHT_PLAN_DB_BASE_URL=https://api.flightplandatabase.com
AVIATION_WEATHER_BASE_URL=https://aviationweather.gov/api/data
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
OPENSKY_BASE_URL=https://opensky-network.org/api
ADSB_LOL_BASE_URL=https://api.adsb.lol
FLIGHT_TRACKING_MODE=auto
AIRPORT_CSV_PATH=../Frontend/public/iata-icao.csv

CACHE_TTL_SECONDS=300
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
